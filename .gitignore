# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# ---------------------------------------------------------------------------
# HormOS: data & ML pipeline
# ---------------------------------------------------------------------------

# Raw datasets — NEVER commit. Treat NHANES/mcPHASES as sensitive by default,
# even though they are de-identified. PhysioNet credentialed data must stay local.
/data/raw/
*.xpt
*.XPT

# Large/exported ML artifacts (model checkpoints, precomputed features).
# Small JSON insight artifacts consumed by API routes are allow-listed below.
/ml/artifacts/*
!/ml/artifacts/.gitkeep
*.onnx
*.pkl
*.joblib
*.parquet
*.h5

# Allow small, versioned insight artifacts consumed by Next.js API routes.
!/data/processed/*.sample.json
!/data/processed/*.sample.csv

# Python
__pycache__/
*.py[cod]
.venv/
venv/
env/
.python-version
.ipynb_checkpoints/
ml/**/.ipynb_checkpoints/

# Secrets
.env
.env.*
!.env.example
