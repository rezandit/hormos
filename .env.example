# HormOS environment variables
# Copy this file to `.env.local` (Next.js) and fill in real values.
# NEVER commit `.env`, `.env.local`, or any file with real secrets.

# ---------------------------------------------------------------------------
# OpenAI (optional in the current iteration).
# Used later for natural-language summarization of statistical insights.
# The core symptom-to-cycle-phase insight is computed from precomputed data
# artifacts and does NOT require an LLM to function.
# ---------------------------------------------------------------------------
OPENAI_API_KEY=

# ---------------------------------------------------------------------------
# App configuration
# ---------------------------------------------------------------------------
# Base URL used by the app when constructing absolute links (optional).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Data pipeline (Python, runs locally/offline — NOT on Vercel).
# Local paths for raw dataset downloads. These directories are git-ignored.
# ---------------------------------------------------------------------------
HORMOS_RAW_DATA_DIR=./data/raw
HORMOS_PROCESSED_DATA_DIR=./data/processed
